<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_mobach" model="ir.ui.view">
        <field name="name">res.company.form.mobach.nui</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <!-- Ajout du champ NUI après le champ TVA/VAT -->
            <field name="vat" position="after">
                <field name="nui" placeholder="ex: M022317978287A"/>
            </field>
        </field>
    </record>
</odoo>