<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- ================================================================
     TEMPLATE PRINCIPAL — Portail de sélection de société
     ================================================================ -->
<template id="portal_landing_template" name="Groupe Mobach Portal Landing">
&lt;!DOCTYPE html&gt;
<html lang="fr">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Groupe MOBACH — Portail d'accueil</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .mobach-bg {
            background-color: #f8fafc;
            background-image: url('/groupe_mobach_portal/static/src/img/fond_portail.png');
            background-size: cover;
            background-position: center center;
            background-repeat: no-repeat;
            background-attachment: fixed;
        }
        .company-card { transition: transform 0.25s ease, box-shadow 0.25s ease; }
        .company-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.13); }
        .card-logo-img {
            width: 88px; height: 88px;
            object-fit: contain; padding: 6px;
            border-radius: 10px; background: #fff;
            border: 1px solid #e2e8f0; flex-shrink: 0;
        }
        .btn-select {
            display: inline-block; width: 100%; text-align: center;
            background-color: #2c6b9e; color: #fff;
            padding: 6px 16px; border-radius: 5px;
            font-size: 12px; font-weight: 700;
            letter-spacing: 0.05em; transition: background-color 0.15s;
            text-decoration: none;
        }
        .btn-select:hover { background-color: #1e517c; color: #fff; }
    </style>
</head>
<body class="mobach-bg text-slate-800 min-h-screen flex flex-col justify-between">

    <!-- Barre supérieure -->
    <header class="bg-[#203a54] text-white px-4 py-2 flex items-center justify-between shadow-md">
        <div class="flex items-center gap-4">
            <div class="grid grid-cols-3 gap-0.5 w-4 h-4">
                <div class="bg-white rounded-sm"/><div class="bg-white rounded-sm"/>
                <div class="bg-white rounded-sm"/><div class="bg-white rounded-sm"/>
                <div class="bg-white rounded-sm"/><div class="bg-white rounded-sm"/>
                <div class="bg-white rounded-sm"/><div class="bg-white rounded-sm"/>
                <div class="bg-white rounded-sm"/>
            </div>
            <span class="font-bold text-lg tracking-wide">odoo</span>
        </div>
    </header>

    <!-- Fil d'Ariane -->
    <div class="bg-white/80 backdrop-blur-sm border-b border-slate-200 px-6 py-2.5 text-xs">
        <div class="max-w-6xl mx-auto font-medium">
            <span class="text-slate-800 font-bold">Tableau de Bord</span>
            <span class="text-slate-400 mx-2">/</span>
            <span class="text-slate-500">Groupe Mobach</span>
        </div>
    </div>

    <!-- Contenu -->
    <main class="flex-1 flex flex-col items-center justify-center px-4 py-8">

        <!-- Accès refusé -->
        <t t-if="access_denied">
            <div class="w-full max-w-2xl mb-6 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-xl flex items-start gap-3 shadow-md">
                <svg class="w-5 h-5 text-red-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
                <div class="text-xs md:text-sm">
                    <span class="font-bold">Accès Refusé :</span>
                    Votre profil n'a pas accès à la société
                    <span class="font-bold text-red-950"><t t-esc="denied_company_name"/></span>.
                    Veuillez choisir une autre société.
                </div>
            </div>
        </t>

        <!-- Titre -->
        <div class="text-center mb-8">
            <h1 class="text-3xl md:text-4xl font-extrabold text-[#203a54] uppercase tracking-wide drop-shadow-sm">GROUPE MOBACH</h1>
            <p class="text-slate-700 text-sm md:text-base font-medium mt-2">Bienvenue sur le portail de gestion du Groupe Mobach</p>
            <p class="text-slate-500 text-xs md:text-sm mt-1">Veuillez sélectionner la société dans laquelle vous souhaitez travailler :</p>
        </div>

        <!-- Grille sociétés -->
        <div class="w-full max-w-4xl">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <t t-foreach="companies" t-as="company">
                    <div class="company-card bg-white/90 backdrop-blur-sm border border-slate-200/80 p-5 rounded-xl shadow-md flex flex-row items-center gap-5">

                        <!-- Logo via URL propre /company_portal/logo/<id> -->
                        <img t-att-src="company['logo_url']"
                             t-att-alt="company['name']"
                             class="card-logo-img"/>

                        <div class="flex-1 flex flex-col justify-between h-full min-h-[96px]">
                            <!-- Stats -->
                            <div class="flex items-center gap-3 text-slate-500 text-[11px] mb-1 font-medium">
                                <div class="flex items-center gap-1">
                                    <svg class="w-3.5 h-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                                    </svg>
                                    <t t-esc="company['collaborators']"/> Collab.
                                </div>
                                <div class="flex items-center gap-1">
                                    <svg class="w-3.5 h-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                                    </svg>
                                    12 Projets
                                </div>
                            </div>
                            <!-- Nom -->
                            <h3 class="text-xl font-bold text-slate-800 leading-tight" t-esc="company['name']"/>
                            <!-- Description -->
                            <p class="text-xs text-slate-500 font-medium mt-0.5" t-esc="company['subtitle']"/>
                            <!-- Bouton : URL propre, company_id uniquement -->
                            <div class="mt-3">
                                <a t-attf-href="/web/login?company_id={{ company['id'] }}"
                                   class="btn-select">
                                    Sélectionner
                                </a>
                            </div>
                        </div>
                    </div>
                </t>
            </div>
        </div>
    </main>

    <!-- Pied de page -->
    <footer class="bg-white/80 backdrop-blur-sm border-t border-slate-200 py-3.5 text-center text-[11px] text-slate-500 font-medium">
        © Odoo <t t-esc="current_year"/> — Groupe Mobach
    </footer>
</body>
</html>
</template>


<!-- ================================================================
     PAGE DE LOGIN — Bouton retour + logo société
     ================================================================
     - Héritage de web.login_layout (template réel du logo en Odoo 19)
     - XPath sur le div parent du logo (attribut alt interdit comme sélecteur)
     - Bouton "← Retour au portail" injecté sous le logo
     - Logo chargé via /company_portal/logo/<id> (URL propre, sans chemin exposé)
     ================================================================ -->
<template id="web_login_mobach"
          inherit_id="web.login_layout"
          name="MOBACH — Logo société + bouton retour sur page de login">

    <xpath expr="//div[contains(@class,'text-center') and contains(@class,'pb-3') and contains(@class,'border-bottom')]"
           position="replace">

        <div class="text-center pb-3 border-bottom mb-4">

            <!-- Logo : servi via /company_portal/logo/<id> si company_id présent,
                 sinon logo natif Odoo (comportement par défaut) -->
            <t t-set="cid" t-value="request.params.get('company_id', '')"/>
            <t t-if="cid">
                <img t-attf-src="/company_portal/logo/{{ cid }}"
                     style="max-height:120px; max-width:100%; width:auto; object-fit:contain;"/>
            </t>
            <t t-else="">
                <img t-attf-src="/web/binary/company_logo{{ '?dbname='+db if db else '' }}"
                     style="max-height:120px; max-width:100%; width:auto;"/>
            </t>

            <!-- Bouton retour vers le portail -->
            <div class="mt-3">
                <a href="/"
                   style="display:inline-flex; align-items:center; gap:6px;
                          font-size:12px; color:#2c6b9e; text-decoration:none;
                          font-weight:600; transition:color 0.15s;"
                   onmouseover="this.style.color='#1e517c'"
                   onmouseout="this.style.color='#2c6b9e'">
                    <!-- Flèche gauche -->
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M19 12H5M12 5l-7 7 7 7"/>
                    </svg>
                    Retour au portail
                </a>
            </div>

        </div>
    </xpath>

</template>

</odoo>
