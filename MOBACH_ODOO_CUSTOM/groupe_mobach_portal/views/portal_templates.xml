<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_landing_template" name="Groupe Mobach Portal Landing">
        &lt;!DOCTYPE html&gt;
        <html lang="fr">
            <head>
                <meta charset="UTF-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
                <title>Groupe MOBACH - Portail d'Aiguillage d'Odoo 19</title>
                <script src="https://cdn.tailwindcss.com"></script>
                <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
                <style>
                    body { font-family: 'Plus Jakarta Sans', sans-serif; }
                </style>
            </head>
            <body class="bg-[#f8fafc] text-slate-800 min-h-screen flex flex-col justify-between selection:bg-[#2c6b9e] selection:text-white">
                
                <!-- En-tête de page Odoo (Top bar de la pièce jointe) -->
                <header class="bg-[#203a54] text-white px-4 py-2 flex items-center justify-between shadow-md">
                    <div class="flex items-center gap-4">
                        <!-- Menu Apps Odoo (Grille 9 points) -->
                        <div class="grid grid-cols-3 gap-0.5 w-4 h-4 cursor-pointer hover:opacity-80">
                            <div class="bg-white rounded-xs"></div>
                            <div class="bg-white rounded-xs"></div>
                            <div class="bg-white rounded-xs"></div>
                            <div class="bg-white rounded-xs"></div>
                            <div class="bg-white rounded-xs"></div>
                            <div class="bg-white rounded-xs"></div>
                            <div class="bg-white rounded-xs"></div>
                            <div class="bg-white rounded-xs"></div>
                            <div class="bg-white rounded-xs"></div>
                        </div>
                        <!-- Logo Odoo -->
                        <span class="font-bold text-lg tracking-wide hover:opacity-90 cursor-pointer">odoo</span>
                    </div>
                </header>

                <!-- Breadcrumb Bar (Fil d'Ariane) -->
                <div class="bg-white border-b border-slate-200 px-6 py-2.5 text-xs">
                    <div class="max-w-6xl mx-auto font-medium">
                        <span class="text-slate-800 font-bold hover:underline cursor-pointer">Tableau de Bord</span>
                        <span class="text-slate-400 mx-2">/</span>
                        <span class="text-slate-500">Groupe Mobach</span>
                    </div>
                </div>

                <!-- Zone Principale avec les croquis d'architecte (Dispositions et Couleurs exactes) -->
                <main class="relative flex-1 flex flex-col items-center justify-center px-4 py-8 overflow-hidden">
                    
                    <!-- Croquis d'Architecte - Gauche (Maison rurale/villa avec tache marron) -->
                    <div class="absolute left-[-60px] md:left-4 bottom-10 w-64 h-64 opacity-25 md:opacity-100 pointer-events-none z-0">
                        <!-- Tache d'aquarelle marron pastel -->
                        <div class="absolute left-4 top-12 w-48 h-32 rounded-full bg-[#f6efe4] blur-xl z-0"></div>
                        <!-- House SVG Sketch -->
                        <svg class="w-full h-full relative z-10 stroke-amber-800/40 fill-none" viewBox="0 0 100 100" stroke-width="0.5">
                            <path d="M10,75 L45,75 L45,45 L10,45 Z" />
                            <path d="M45,75 L85,75 L85,45 L45,45 Z" />
                            <path d="M10,45 L27,20 L45,45" />
                            <path d="M45,45 L65,20 L85,45" />
                            <path d="M27,20 L65,20" />
                            <path d="M20,75 L20,55 L35,55 L35,75 Z" />
                            <circle cx="65" cy="55" r="6" />
                            <line x1="10" y1="75" x2="90" y2="75" stroke-width="0.8" />
                            <line x1="25" y1="30" x2="25" y2="15" />
                            <line x1="28" y1="30" x2="28" y2="15" />
                        </svg>
                    </div>

                    <!-- Croquis d'Architecte - Droite (Grue de chantier & Immeuble avec tache verte) -->
                    <div class="absolute right-[-60px] md:right-4 top-16 w-72 h-72 opacity-25 md:opacity-100 pointer-events-none z-0">
                        <!-- Tache d'aquarelle verte pastel -->
                        <div class="absolute right-8 top-12 w-44 h-44 rounded-full bg-[#e8f2ec] blur-xl z-0"></div>
                        <!-- Crane & Building SVG Sketch -->
                        <svg class="w-full h-full relative z-10 stroke-emerald-800/40 fill-none" viewBox="0 0 100 100" stroke-width="0.5">
                            <line x1="80" y1="90" x2="80" y2="10" stroke-width="0.8" />
                            <line x1="80" y1="15" x2="30" y2="15" stroke-width="0.8" />
                            <line x1="80" y1="15" x2="95" y2="15" stroke-width="0.6" />
                            <path d="M80,15 L30,40 L80,40 Z" />
                            <line x1="45" y1="15" x2="45" y2="90" />
                            <line x1="30" y1="15" x2="30" y2="40" />
                            <rect x="15" y="45" width="25" height="45" />
                            <rect x="20" y="50" width="5" height="8" />
                            <rect x="30" y="50" width="5" height="8" />
                            <rect x="20" y="65" width="5" height="8" />
                            <rect x="30" y="65" width="5" height="8" />
                            <line x1="5" y1="90" x2="95" y2="90" stroke-width="0.8" />
                        </svg>
                    </div>

                    <!-- Notification Accès Refusé -->
                    <t t-if="access_denied">
                        <div class="w-full max-w-2xl mb-6 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-xl flex items-start gap-3 shadow-md z-10">
                            <svg class="w-5 h-5 text-red-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                            </svg>
                            <div class="text-xs md:text-sm">
                                <span class="font-bold">Accès Refusé :</span> Votre profil Odoo n'a pas été habilité à travailler pour la filiale <span class="font-bold text-red-950"><t t-esc="denied_company_name"/></span>. Veuillez choisir une autre société.
                            </div>
                        </div>
                    </t>

                    <!-- Titre de bienvenue -->
                    <div class="text-center mb-8 z-10">
                        <h1 class="text-3xl md:text-4xl font-extrabold text-[#203a54] uppercase tracking-wide">GROUPE MOBACH</h1>
                        <p class="text-slate-700 text-sm md:text-base font-medium mt-2">Bienvenue sur le portail de gestion du Groupe Mobach</p>
                        <p class="text-slate-500 text-xs md:text-sm mt-1">Veuillez sélectionner la société dans laquelle vous souhaitez travailler :</p>
                    </div>

                    <!-- Grille de cartes (Dispositions 2 par ligne de la pièce jointe) -->
                    <div class="w-full max-w-4xl z-10">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            
                            <t t-foreach="companies" t-as="company">
                                <div class="bg-white border border-slate-200/80 p-5 rounded-xl shadow-md hover:shadow-lg transition-all duration-300 flex flex-row items-center gap-5">
                                    
                                    <!-- LOGO (À GAUCHE) : Boitier blanc carré avec bordure grise -->
                                    <div class="w-24 h-24 border border-slate-200 rounded-lg flex flex-col items-center justify-center p-2 bg-white flex-shrink-0 shadow-inner overflow-hidden">
                                        <!-- Logo MOBACH -->
                                        <t t-if="company['logo_type'] == 'mobach'">
                                            <span class="font-serif text-5xl font-black text-[#203a54] leading-none">M</span>
                                            <span class="text-[7px] font-extrabold tracking-wider text-slate-800 uppercase mt-0.5">MOBACH SARL</span>
                                        </t>
                                        <!-- Logo NAS et Fils -->
                                        <t t-if="company['logo_type'] == 'nas'">
                                            <svg class="w-12 h-10 text-[#a67c33]" viewBox="0 0 24 20" fill="currentColor">
                                                <!-- Sunburst rays -->
                                                <path d="M12 1a1 1 0 011 1v2a1 1 0 11-2 0V2a1 1 0 011-1zm6.364 2.636a1 1 0 010 1.414l-1.414 1.414a1 1 0 11-1.414-1.414l1.414-1.414a1 1 0 011.414 0zM22 9a1 1 0 01-1 1h-2a1 1 0 110-2h2a1 1 0 011 1zm-3.636 5.364a1 1 0 01-1.414 0l-1.414-1.414a1 1 0 111.414-1.414l1.414 1.414a1 1 0 010 1.414zM12 15a1 1 0 011 1v2a1 1 0 11-2 0v-2a1 1 0 011-1zm-6.364-2.636a1 1 0 010-1.414l1.414-1.414a1 1 0 111.414 1.414l-1.414 1.414a1 1 0 01-1.414 0zM3 9a1 1 0 01-1-1h2a1 1 0 110 2H3zm2.636-5.364a1 1 0 011.414 0l1.414 1.414a1 1 0 11-1.414 1.414L5.636 5.05a1 1 0 010-1.414z" />
                                                <!-- Overlapping text placeholder -->
                                                <text x="12" y="16" font-family="Georgia" font-weight="bold" font-size="7" text-anchor="middle" fill="#a67c33">N&amp;F</text>
                                            </svg>
                                            <span class="text-[7px] font-extrabold text-[#a67c33] uppercase mt-0.5">NAS et Fils</span>
                                        </t>
                                        <!-- Logo MB SARL -->
                                        <t t-if="company['logo_type'] == 'mb'">
                                            <svg class="w-full h-full" viewBox="0 0 100 100">
                                                <defs>
                                                    <linearGradient id="goldGradXml" x1="0%" y1="0%" x2="100%" y2="100%">
                                                    <stop offset="0%" stop-color="#f3e092"/>
                                                    <stop offset="30%" stop-color="#d4af37"/>
                                                    <stop offset="70%" stop-color="#aa7c11"/>
                                                    <stop offset="100%" stop-color="#8b6508"/>
                                                    </linearGradient>
                                                </defs>
                                                <!--  Outer gold shield  -->
                                                <path d="M 22 12 Q 50 7 78 12 C 78 40 73 68 50 88 C 27 68 22 40 22 12 Z" fill="url(#goldGradXml)" stroke="#ffd700" stroke-width="2"/>
                                                <!--  Inner gold shield border line  -->
                                                <path d="M 27 16 Q 50 11.5 73 16 C 73 38 68 63 50 81 C 32 63 27 38 27 16 Z" fill="none" stroke="#ffffff" stroke-width="1" stroke-opacity="0.6"/>
                                                <!--  Initiales "MB" centered with shadow effect  -->
                                                <text x="52" y="56" font-family="Georgia, serif" font-weight="900" font-size="28" letter-spacing="-1" text-anchor="middle" fill="#5c4008">MB</text>
                                                <text x="50" y="54" font-family="Georgia, serif" font-weight="900" font-size="28" letter-spacing="-1" text-anchor="middle" fill="#ffffff">MB</text>
                                                <!--  Subtitle below MB  -->
                                                <text x="50" y="70" font-family="'Plus Jakarta Sans', sans-serif" font-weight="800" font-size="6.5" text-anchor="middle" fill="#ffffff" letter-spacing="0.5">MB SARL</text>
                                            </svg>
                                        </t>
                                        <!-- Logo AFRI DRIVE -->
                                        <t t-if="company['logo_type'] == 'afridrive'">
                                            <svg class="w-12 h-12 text-blue-600 relative" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                                                <circle cx="12" cy="12" r="10" stroke="currentColor" />
                                                <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10M12 2a15.3 15.3 0 00-4 10 15.3 15.3 0 004 10" />
                                                <path d="M2 12h20" />
                                                <!-- Red truck & arrow indicators -->
                                                <path d="M12 8 L20 12 L12 16 Z" fill="red" stroke="red" />
                                            </svg>
                                            <span class="text-[7px] font-black text-red-600 uppercase mt-0.5">AFRI DRIVE</span>
                                        </t>
                                    </div>

                                    <!-- INFOS (À DROITE) -->
                                    <div class="flex-1 flex flex-col justify-between h-full min-h-[96px]">
                                        
                                        <!-- Meta : Collaborateurs et Projets en ligne -->
                                        <div class="flex items-center gap-3 text-slate-500 text-[11px] mb-1 font-medium">
                                            <!-- Collab Icon & Count -->
                                            <div class="flex items-center gap-1">
                                                <svg class="w-3.5 h-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                                                </svg>
                                                <span t-esc="company['collaborators']"/> Collab.
                                            </div>
                                            <!-- Projet Icon & Static template count -->
                                            <div class="flex items-center gap-1">
                                                <svg class="w-3.5 h-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                                                </svg>
                                                <span>12 Projets</span>
                                            </div>
                                        </div>

                                        <!-- Nom de la société -->
                                        <h3 class="text-xl font-bold text-slate-800 leading-tight" t-esc="company['name']"/>
                                        
                                        <!-- Sous-titre ou activité -->
                                        <p class="text-xs text-slate-500 font-medium mt-0.5" t-esc="company['subtitle']"/>

                                        <!-- Bouton Sélectionner de couleur Odoo Bleu-Gris -->
                                        <div class="mt-3">
                                            <a t-attf-href="/web/login?company_id={{ company['id'] }}" 
                                               class="inline-block w-full bg-[#2c6b9e] hover:bg-[#1e517c] text-white text-center py-1.5 px-6 rounded text-xs font-bold tracking-wider transition duration-150 shadow-sm">
                                                Sélectionner
                                            </a>
                                        </div>
                                    </div>

                                </div>
                            </t>

                        </div>
                    </div>
                </main>

                <!-- Pied de page Odoo d'origine -->
                <footer class="bg-white border-t border-slate-200 py-3.5 text-center text-[11px] text-slate-500 font-medium">
                    &amp;copy; Odoo <t t-esc="current_year"/> - Groupe Mobach
                </footer>

            </body>
        </html>
    </template>
</odoo>
