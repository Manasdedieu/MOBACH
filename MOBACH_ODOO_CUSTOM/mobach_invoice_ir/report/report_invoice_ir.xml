<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Rapport PDF — MOBACH IR
        ========================
        Héritage de account.document_tax_totals (primary template Odoo 19).

        Ordre final dans le PDF :
          Total HT           10 000 000
          TVA 19,25%          1 925 000
          ─────────────────────────────
          IR 2,2%               220 000
          Net à Mandater      9 780 000
          ─────────────────────────────
          Total TTC          11 925 000
    -->
    <template id="document_tax_totals_mobach_ir"
              inherit_id="account.document_tax_totals"
              name="MOBACH — IR, Net à Mandater et Total TTC (PDF)">

        <!-- Injection IR + Net à Mandater avant la ligne Total -->
        <xpath expr="//tr[hasclass('o_total')]" position="before">
            <t t-if="o and o.ir_tax_id">

                <!-- Ligne séparatrice -->
                <tr>
                    <td colspan="2" style="padding: 0;">
                        <hr style="margin: 3px 0; border-color: #dee2e6;"/>
                    </td>
                </tr>

                <!-- IR -->
                <tr>
                    <td style="color: #6c757d;">
                        <t t-out="o.ir_tax_id.name"/>
                    </td>
                    <td class="text-end" style="color: #6c757d;">
                        <span t-out="o.ir_amount"
                              t-options='{"widget": "monetary", "display_currency": currency}'/>
                    </td>
                </tr>

                <!-- Séparateur fort -->
                <tr>
                    <td colspan="2" style="padding: 0;">
                        <hr style="margin: 3px 0; border-color: #adb5bd; border-width: 2px;"/>
                    </td>
                </tr>

                <!-- Net à Mandater -->
                <tr>
                    <td><strong>Net à Mandater</strong></td>
                    <td class="text-end">
                        <strong t-out="o.amount_net_mandate"
                                t-options='{"widget": "monetary", "display_currency": currency}'/>
                    </td>
                </tr>

                <!-- Séparateur avant Total TTC -->
                <tr>
                    <td colspan="2" style="padding: 0;">
                        <hr style="margin: 3px 0; border-color: #dee2e6;"/>
                    </td>
                </tr>

            </t>
        </xpath>

        <!-- "Total" → "Total TTC" dans le PDF -->
        <xpath expr="//tr[hasclass('o_total')]/td[1]" position="replace">
            <td><strong>Total TTC</strong></td>
        </xpath>

    </template>

</odoo>
